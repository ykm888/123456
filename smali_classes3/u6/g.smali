05\u00ba\u0003\u0000\r\u00ba\u0001\u0000\u0005\u00ba\u0001\u0000\u0003\u00ba\u0004\u0000\u0004\u00ba\u0002\u0000\u0008\u00ba\u001b\u0000\u0001\u00ba?\u0000\u000e\u0135\u0001\u0000\u0001\u0136\u0001\u0000\u0001\u0135\u0001\u0137\u0001\u0000\u0005\u0135\u0003\u0000\r\u0135\u0001\u0137\u0005\u0135\u0001\u0000\u0003\u0135\u0004\u0000\u0004\u0135\u0002\u0000\u0008\u0135\u000b\u0000\u000e\u00bd\u0001\u0000\u0001\u00be\u0001\u0000\u0001\u00bd\u0002\u0000\u0005\u00bd\u0003\u0000\r\u00bd\u0001\u0000\u0005\u00bd\u0001\u0000\u0003\u00bd\u0004\u0000\u0004\u00bd\u0002\u0000\u0008\u00bd\u001b\u0000\u0001\u00bd?\u0000\u000e\u0138\u0001\u0000\u0001\u0139\u0001\u0000\u0001\u0138\u0001\u013a\u0001\u0000\u0005\u0138\u0003\u0000\r\u0138\u0001\u013a\u0005\u0138\u0001\u0000\u0003\u0138\u0004\u0000\u0004\u0138\u0002\u0000\u0008\u0138\u000b\u0000\u0001\u00c0\u0001\u000b\u0004\u00c0\u0001\u000b\u0001L\u0002\u000b\u0001\u00c0\u0001N\u0001\u000b\u0001\u00c0\u0001\u013b\u0001P\u0001\u0000\u0001\u000b\u0002\u0000\u0001\u00c0\u0001\u000b\u0001\u00c0\u0001\u000b\u0001Q\u0003\u0000\u0001\u00c0\u0001Q\u0001\u00c0\u0001R\u0001\u000b\u0001L\u0001\u00c0\u0003\u000b\u0001N\u0001\u000b\u0001\u00c0\u0001\u0000\u0005\u000b\u0001\u0000\u0001\u000b\u0001R\u0001\u00c0\u0004\u0000\u0004\u000b\u0002\u0000\u0001\u00c0\u0001\u000b\u0005\u00c0\u0001\u000b\u000b\u0000\u0001\u013b\u0001\u0000\u0004\u013b\u0004\u0000\u0001\u013b\u0002\u0000\u0001\u013b\u0006\u0000\u0001\u013b\u0001\u0000\u0001\u013b\u0005\u0000\u0001\u013b\u0001\u0000\u0001\u013b\u0003\u0000\u0001\u013b\u0005\u0000\u0001\u013b\t\u0000\u0001\u013b\n\u0000\u0001\u013b\u0001\u0000\u0005\u013b\u000c\u0000\u0001\u00c2\u0002\u000b\u0002\u00c2\u0005\u000b\u0001M\u0003\u000b\u0001\u0000\u0001P\u0001\u0000\u0001\u000b\u0002\u0000\u0002\u000b\u0001M\u0002\u000b\u0003\u0000\u000c\u000b\u0001S\u0001\u0000\u0005\u000b\u0001\u0000\u0002\u000b\u0001S\u0004\u0000\u0004\u000b\u0002\u0000\u0001\u00c2\u0001\u000b\u0005\u00c2\u0001\u000b\u000b\u0000\u0001\u00c2\u0002\u